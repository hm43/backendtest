{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/api/**/*",
    "src/config/**/*",
    "controllers/**/*",
    "src/routes/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}